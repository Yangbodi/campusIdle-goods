<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 校园闲置好物阁</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CampusIdleGoods.styles.css" asp-append-version="true" />
</head>
<body>
    <header style="background:rgba(255, 255, 255, .7);">
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-shop me-1"></i> 校园闲置好物阁
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i> 首页
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Product" asp-action="Browse">
                                <i class="bi bi-grid me-1"></i> 商品浏览
                            </a>
                        </li>
                        @if (CampusIdleGoods.Helpers.SessionHelper.IsLoggedIn(Context.Session))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Product" asp-action="Create">
                                    <i class="bi bi-plus-circle me-1"></i> 发布商品
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Product" asp-action="MyProducts">
                                    <i class="bi bi-bag-check me-1"></i> 我的商品
                                </a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (CampusIdleGoods.Helpers.SessionHelper.IsLoggedIn(Context.Session))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle me-1"></i>
                                    @CampusIdleGoods.Helpers.SessionHelper.GetUsername(Context.Session)
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                            <i class="bi bi-person-badge me-2"></i>个人中心
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Product" asp-action="MyProducts">
                                            <i class="bi bi-bag-check me-2"></i>我的商品
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Message" asp-action="Index">
                                            <i class="bi bi-chat-dots me-2"></i>消息
                                            <span id="unreadMessageCount" class="badge bg-danger ms-1" style="display: none;">0</span>
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Favorite" asp-action="Index">
                                            <i class="bi bi-heart-fill me-2"></i>我的收藏
                                        </a>
                                    </li>
                                    @if (CampusIdleGoods.Helpers.SessionHelper.IsAdmin(Context.Session))
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Admin" asp-action="Dashboard">
                                                <i class="bi bi-shield-check me-2"></i>管理后台
                                            </a>
                                        </li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="bi bi-box-arrow-right me-2"></i>登出
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i> 登录
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-light text-primary ms-2" asp-controller="Account" asp-action="Register" style="border-radius: 0.5rem; text-decoration: none;">
                                    <i class="bi bi-person-plus me-1"></i> 注册
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid px-0">
        <main role="main" class="pb-3">
            <div class="container mt-4">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/js/siganalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        // 加载未读消息数量
        @if (CampusIdleGoods.Helpers.SessionHelper.IsLoggedIn(Context.Session))
        {
            <text>
            fetch('@Url.Action("GetUnreadCount", "Message")')
                .then(response => response.json())
                .then(data => {
                    const badge = document.getElementById('unreadMessageCount');
                    if (badge && data.count > 0) {
                        badge.textContent = data.count;
                        badge.style.display = 'inline';
                    }
                })
                .catch(error => console.error('Error loading unread count:', error));

            </text>
        }
    </script>
</body>
</html>