@model ProductSearchViewModel
@using CampusIdleGoods.Models
@{
    ViewData["Title"] = "浏览商品";
    var products = ViewBag.Products as List<Product> ?? new List<Product>();
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
}

<div class="row g-4">
    <!-- 筛选侧边栏 -->
    <div class="col-md-3">
        <div class="card fade-in">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-funnel"></i> 筛选条件</h5>
            </div>
            <div class="card-body">
                <form asp-action="Browse" method="get" id="filterForm">
                    <input type="hidden" name="Page" value="1" />

                    <!-- 关键词搜索 -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">关键词</label>
                        <input type="text" name="Keyword" class="form-control" value="@Model.Keyword" placeholder="搜索商品...">
                    </div>

                    <!-- 分类筛选 -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">分类</label>
                        <select name="CategoryId" class="form-select">
                            <option value="">全部分类</option>
                            @foreach (var category in categories)
                            {
                                <option value="@category.Id" selected="@(Model.CategoryId == category.Id)">@category.Name</option>
                            }
                        </select>
                    </div>

                    <!-- 价格筛选 -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">价格区间</label>
                        <div class="row g-2">
                            <div class="col-6">
                                <input type="number" name="MinPrice" class="form-control" value="@Model.MinPrice" placeholder="最低价" step="0.01" min="0">
                            </div>
                            <div class="col-6">
                                <input type="number" name="MaxPrice" class="form-control" value="@Model.MaxPrice" placeholder="最高价" step="0.01" min="0">
                            </div>
                        </div>
                    </div>

                    <!-- 时间筛选 -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">发布时间</label>
                        <select name="TimeFilter" class="form-select">
                            <option value="">不限</option>
                            <option value="24h" selected="@(Model.TimeFilter == "24h")">24小时内</option>
                            <option value="7d" selected="@(Model.TimeFilter == "7d")">一周内</option>
                            <option value="30d" selected="@(Model.TimeFilter == "30d")">一个月内</option>
                        </select>
                    </div>

                    <!-- 排序方式 -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">排序方式</label>
                        <select name="SortBy" class="form-select">
                            <option value="latest" selected="@(Model.SortBy == "latest" || string.IsNullOrEmpty(Model.SortBy))">最新发布</option>
                            <option value="price_asc" selected="@(Model.SortBy == "price_asc")">价格从低到高</option>
                            <option value="price_desc" selected="@(Model.SortBy == "price_desc")">价格从高到低</option>
                            <option value="views" selected="@(Model.SortBy == "views")">最多浏览</option>
                        </select>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search"></i> 搜索
                        </button>
                        <a asp-action="Browse" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-clockwise"></i> 重置
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- 商品列表 -->
    <div class="col-md-9">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="fw-bold mb-0">
                商品列表
                @if (Model.TotalCount > 0)
                {
                    <small class="text-muted">(共 @Model.TotalCount 件商品)</small>
                }
            </h4>
        </div>

        @if (!products.Any())
        {
            <div class="card text-center py-5">
                <div class="card-body">
                    <i class="bi bi-inbox fs-1 text-muted mb-3"></i>
                    <h5 class="text-muted">暂无商品</h5>
                    <p class="text-muted">试试调整筛选条件或搜索其他关键词</p>
                </div>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var product in products)
                {
                    <div class="col-md-6 col-lg-4">
                        <a asp-action="Details" asp-route-id="@product.Id" class="text-decoration-none">
                            <div class="card h-100 product-card fade-in">
                                @if (product.Images != null && product.Images.Any())
                                {
                                    <img src="@product.Images.First().ImagePath" class="card-img-top" alt="@product.Title" style="height: 200px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                        <i class="bi bi-image fs-1 text-muted"></i>
                                    </div>
                                }
                                <div class="card-body d-flex flex-column">
                                    <h6 class="card-title text-dark mb-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 48px;">@product.Title</h6>
                                    <div class="mb-2">
                                        <span class="h6 text-primary fw-bold">¥@product.Price.ToString("F2")</span>
                                        @if (product.OriginalPrice.HasValue)
                                        {
                                            <span class="text-muted text-decoration-line-through small ms-1">¥@product.OriginalPrice.Value.ToString("F2")</span>
                                        }
                                    </div>
                                    <div class="mb-2">
                                        <span class="badge bg-light text-dark">@product.Category.Name</span>
                                        @if (product.IsNegotiable)
                                        {
                                            <span class="badge bg-primary ms-1">可议价</span>
                                        }
                                    </div>
                                    <div class="mt-auto">
                                        <small class="text-muted">
                                            <i class="bi bi-eye"></i> @product.ViewCount | 
                                            <i class="bi bi-clock"></i> @product.CreatedAt.ToString("MM-dd")
                                        </small>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>

            <!-- 分页 -->
            @if (Model.TotalPages > 1)
            {
                <nav aria-label="商品分页" class="mt-4">
                    <ul class="pagination justify-content-center">
                        @if (Model.Page > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="?@GetPageUrl(Model.Page - 1)">上一页</a>
                            </li>
                        }
                        @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.TotalPages, Model.Page + 2); i++)
                        {
                            <li class="page-item @(i == Model.Page ? "active" : "")">
                                <a class="page-link" href="?@GetPageUrl(i)">@i</a>
                            </li>
                        }
                        @if (Model.Page < Model.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" href="?@GetPageUrl(Model.Page + 1)">下一页</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
    </div>
</div>

@functions {
    private string GetPageUrl(int page)
    {
        var queryParams = new System.Collections.Generic.List<string>();
        if (!string.IsNullOrEmpty(Model.Keyword))
            queryParams.Add($"Keyword={Uri.EscapeDataString(Model.Keyword)}");
        if (Model.CategoryId.HasValue)
            queryParams.Add($"CategoryId={Model.CategoryId.Value}");
        if (Model.MinPrice.HasValue)
            queryParams.Add($"MinPrice={Model.MinPrice.Value}");
        if (Model.MaxPrice.HasValue)
            queryParams.Add($"MaxPrice={Model.MaxPrice.Value}");
        if (!string.IsNullOrEmpty(Model.TimeFilter))
            queryParams.Add($"TimeFilter={Model.TimeFilter}");
        if (!string.IsNullOrEmpty(Model.SortBy))
            queryParams.Add($"SortBy={Model.SortBy}");
        queryParams.Add($"Page={page}");
        return string.Join("&", queryParams);
    }
}

@section Scripts {
    <script>
        // 商品卡片悬停效果
        document.querySelectorAll('.product-card').forEach(card => {
            card.addEventListener('mouseenter', function() {
                this.style.transform = 'translateY(-5px)';
                this.style.transition = 'transform 0.3s';
            });
            card.addEventListener('mouseleave', function() {
                this.style.transform = 'translateY(0)';
            });
        });
    </script>
}

