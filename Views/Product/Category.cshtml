@model dynamic
@using CampusIdleGoods.Models
@{
    ViewData["Title"] = ViewBag.Category?.Name ?? "分类浏览";
    var category = ViewBag.Category as Category;
    var products = ViewBag.Products as List<Product> ?? new List<Product>();
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var totalCount = ViewBag.TotalCount as int? ?? 0;
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">首页</a></li>
            <li class="breadcrumb-item"><a asp-controller="Product" asp-action="Browse">商品浏览</a></li>
            <li class="breadcrumb-item active">@(category?.Name ?? "分类")</li>
        </ol>
    </nav>
    <h3 class="fw-bold mb-0">@(category?.Name ?? "分类")</h3>
    @if (!string.IsNullOrEmpty(category?.Description))
    {
        <p class="text-muted">@category.Description</p>
    }
    @if (totalCount > 0)
    {
        <p class="text-muted">共找到 @totalCount 件商品</p>
    }
</div>

@if (!products.Any())
{
    <div class="card text-center py-5">
        <div class="card-body">
            <i class="bi bi-inbox fs-1 text-muted mb-3"></i>
            <h5 class="text-muted">该分类下暂无商品</h5>
            <a asp-controller="Product" asp-action="Browse" class="btn btn-primary mt-3">浏览所有商品</a>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var product in products)
        {
            <div class="col-md-6 col-lg-4">
                <a asp-action="Details" asp-route-id="@product.Id" class="text-decoration-none">
                    <div class="card h-100 product-card fade-in">
                        @if (product.Images != null && product.Images.Any())
                        {
                            <img src="@product.Images.First().ImagePath" class="card-img-top" alt="@product.Title" style="height: 200px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                <i class="bi bi-image fs-1 text-muted"></i>
                            </div>
                        }
                        <div class="card-body d-flex flex-column">
                            <h6 class="card-title text-dark mb-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 48px;">@product.Title</h6>
                            <div class="mb-2">
                                <span class="h6 text-primary fw-bold">¥@product.Price.ToString("F2")</span>
                                @if (product.OriginalPrice.HasValue)
                                {
                                    <span class="text-muted text-decoration-line-through small ms-1">¥@product.OriginalPrice.Value.ToString("F2")</span>
                                }
                            </div>
                            <div class="mb-2">
                                @if (product.IsNegotiable)
                                {
                                    <span class="badge bg-primary">可议价</span>
                                }
                            </div>
                            <div class="mt-auto">
                                <small class="text-muted">
                                    <i class="bi bi-eye"></i> @product.ViewCount | 
                                    <i class="bi bi-clock"></i> @product.CreatedAt.ToString("MM-dd")
                                </small>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>

    <!-- 分页 -->
    @if (totalPages > 1)
    {
        <nav aria-label="商品分页" class="mt-4">
            <ul class="pagination justify-content-center">
                @if (currentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Category" asp-route-id="@category.Id" asp-route-page="@(currentPage - 1)">上一页</a>
                    </li>
                }
                @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" asp-action="Category" asp-route-id="@category.Id" asp-route-page="@i">@i</a>
                    </li>
                }
                @if (currentPage < totalPages)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Category" asp-route-id="@category.Id" asp-route-page="@(currentPage + 1)">下一页</a>
                    </li>
                }
            </ul>
        </nav>
    }
}

@section Scripts {
    <script>
        // 商品卡片悬停效果
        document.querySelectorAll('.product-card').forEach(card => {
            card.addEventListener('mouseenter', function() {
                this.style.transform = 'translateY(-5px)';
                this.style.transition = 'transform 0.3s';
            });
            card.addEventListener('mouseleave', function() {
                this.style.transform = 'translateY(0)';
            });
        });
    </script>
}

