@using CampusIdleGoods.Models
@{
    ViewData["Title"] = "用户详情";
    var user = ViewBag.User as User;
    var stats = ViewBag.Stats as dynamic;
}

@if (user == null)
{
    <div class="alert alert-danger">用户不存在</div>
    return;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold">用户详情</h3>
    <div>
        <a asp-action="Users" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> 返回列表
        </a>
        <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-primary">
            <i class="bi bi-pencil"></i> 编辑用户
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-8">
        <!-- 基本信息 -->
        <div class="card fade-in">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-person"></i> 基本信息</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">用户ID：</dt>
                    <dd class="col-sm-9">@user.Id</dd>

                    <dt class="col-sm-3">用户名：</dt>
                    <dd class="col-sm-9">
                        <strong>@user.Username</strong>
                        @if (user.IsAdmin)
                        {
                            <span class="badge bg-danger ms-2">管理员</span>
                        }
                    </dd>

                    <dt class="col-sm-3">真实姓名：</dt>
                    <dd class="col-sm-9">@user.RealName</dd>

                    <dt class="col-sm-3">学号：</dt>
                    <dd class="col-sm-9">@user.StudentId</dd>

                    <dt class="col-sm-3">邮箱：</dt>
                    <dd class="col-sm-9">
                        @user.Email
                        @if (user.IsEmailVerified)
                        {
                            <span class="badge bg-success ms-2">已验证</span>
                        }
                        else
                        {
                            <span class="badge bg-warning ms-2">未验证</span>
                        }
                    </dd>

                    <dt class="col-sm-3">院系专业：</dt>
                    <dd class="col-sm-9">@(user.Department ?? "未填写")</dd>

                    <dt class="col-sm-3">手机号：</dt>
                    <dd class="col-sm-9">@(user.PhoneNumber ?? "未填写")</dd>

                    <dt class="col-sm-3">微信：</dt>
                    <dd class="col-sm-9">@(user.WeChat ?? "未填写")</dd>

                    <dt class="col-sm-3">QQ：</dt>
                    <dd class="col-sm-9">@(user.QQ ?? "未填写")</dd>

                    <dt class="col-sm-3">状态：</dt>
                    <dd class="col-sm-9">
                        @if (user.IsVerified)
                        {
                            <span class="badge bg-success">已认证</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">未认证</span>
                        }
                        @if (user.IsEnabled)
                        {
                            <span class="badge bg-primary">已启用</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">已禁用</span>
                        }
                    </dd>

                    <dt class="col-sm-3">注册时间：</dt>
                    <dd class="col-sm-9">@user.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</dd>

                    <dt class="col-sm-3">更新时间：</dt>
                    <dd class="col-sm-9">@user.UpdatedAt.ToString("yyyy-MM-dd HH:mm:ss")</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <!-- 统计信息 -->
        <div class="card fade-in mb-3">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-bar-chart"></i> 数据统计</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div class="d-flex justify-content-between">
                        <span>发布商品：</span>
                        <strong>@stats.TotalProducts</strong>
                    </div>
                    <small class="text-muted">已上架：@stats.PublishedProducts</small>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between">
                        <span>收藏商品：</span>
                        <strong>@stats.TotalFavorites</strong>
                    </div>
                </div>
                <div>
                    <div class="d-flex justify-content-between">
                        <span>消息数量：</span>
                        <strong>@stats.TotalMessages</strong>
                    </div>
                </div>
            </div>
        </div>

        <!-- 头像 -->
        @if (!string.IsNullOrEmpty(user.AvatarPath))
        {
            <div class="card fade-in">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-image"></i> 头像</h5>
                </div>
                <div class="card-body text-center">
                    <img src="@user.AvatarPath" class="img-fluid rounded-circle" style="max-width: 200px;" alt="用户头像">
                </div>
            </div>
        }
    </div>
</div>

