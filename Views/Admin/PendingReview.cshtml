@{
    ViewData["Title"] = "待审核商品";
    var products = ViewBag.Products as List<CampusIdleGoods.Models.Product> ?? new List<CampusIdleGoods.Models.Product>();
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var totalCount = ViewBag.TotalCount as int? ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold">待审核商品</h3>
    <div>
        <button type="button" class="btn btn-success" id="batchApproveBtn" style="display: none;">
            <i class="bi bi-check-all"></i> 批量通过
        </button>
    </div>
</div>

@if (!products.Any())
{
    <div class="card text-center py-5">
        <div class="card-body">
            <i class="bi bi-check-circle fs-1 text-success mb-3"></i>
            <h5 class="text-muted">暂无待审核商品</h5>
            <p class="text-muted">所有商品都已审核完毕</p>
        </div>
    </div>
}
else
{
    <div class="card fade-in">
        <div class="card-body">
            @Html.AntiForgeryToken()
            <form id="reviewForm">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th width="40">
                                    <input type="checkbox" id="selectAll" />
                                </th>
                                <th>商品信息</th>
                                <th>卖家</th>
                                <th>分类</th>
                                <th>价格</th>
                                <th>发布时间</th>
                                <th>操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in products)
                            {
                                <tr>
                                    <td>
                                        <input type="checkbox" class="product-checkbox" value="@product.Id" />
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            @if (product.Images != null && product.Images.Any())
                                            {
                                                <img src="@product.Images.First().ImagePath" class="me-2" style="width: 60px; height: 60px; object-fit: cover; border-radius: 0.25rem;">
                                            }
                                            <div>
                                                <strong>@product.Title</strong>
                                                <br>
                                                <small class="text-muted" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; max-width: 300px;">
                                                    @product.Description
                                                </small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div>
                                            <strong>@product.Seller.RealName</strong>
                                            <br>
                                            <small class="text-muted">@product.Seller.Username</small>
                                        </div>
                                    </td>
                                    <td>@product.Category.Name</td>
                                    <td class="text-primary fw-bold">¥@product.Price.ToString("F2")</td>
                                    <td>@product.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>
                                        <a asp-action="ReviewProduct" asp-route-id="@product.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i> 审核
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </form>

            <!-- 分页 -->
            @if (totalPages > 1)
            {
                <nav aria-label="分页" class="mt-4">
                    <ul class="pagination justify-content-center">
                        @if (currentPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="PendingReview" asp-route-page="@(currentPage - 1)">上一页</a>
                            </li>
                        }
                        @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link" asp-action="PendingReview" asp-route-page="@i">@i</a>
                            </li>
                        }
                        @if (currentPage < totalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="PendingReview" asp-route-page="@(currentPage + 1)">下一页</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </div>
    </div>
}

@section Scripts {
    <script>
        // 全选/取消全选
        document.getElementById('selectAll')?.addEventListener('change', function() {
            const checkboxes = document.querySelectorAll('.product-checkbox');
            checkboxes.forEach(cb => cb.checked = this.checked);
            updateBatchButton();
        });

        // 单个复选框变化
        document.querySelectorAll('.product-checkbox').forEach(checkbox => {
            checkbox.addEventListener('change', updateBatchButton);
        });

        function updateBatchButton() {
            const checked = document.querySelectorAll('.product-checkbox:checked');
            const batchBtn = document.getElementById('batchApproveBtn');
            if (checked.length > 0) {
                batchBtn.style.display = 'inline-block';
                batchBtn.textContent = `批量通过 (${checked.length})`;
            } else {
                batchBtn.style.display = 'none';
            }
        }

        // 批量审核通过
        document.getElementById('batchApproveBtn')?.addEventListener('click', function() {
            const checked = Array.from(document.querySelectorAll('.product-checkbox:checked'))
                .map(cb => parseInt(cb.value));
            
            if (checked.length === 0) {
                alert('请选择要审核的商品');
                return;
            }

            if (!confirm(`确定要批量审核通过 ${checked.length} 个商品吗？`)) {
                return;
            }

            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            fetch('@Url.Action("BatchApprove", "Admin")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token || '',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify(checked)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert(data.message);
                    location.reload();
                } else {
                    alert(data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('操作失败，请稍后重试');
            });
        });
    </script>
}

