@using CampusIdleGoods.Models
@{
    ViewData["Title"] = "用户管理";
    var users = ViewBag.Users as List<User> ?? new List<User>();
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var totalCount = ViewBag.TotalCount as int? ?? 0;
    var search = ViewBag.Search as string ?? "";
    var filter = ViewBag.Filter as string ?? "all";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold">用户管理</h3>
    <a asp-action="Dashboard" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> 返回仪表板
    </a>
</div>

<!-- 搜索和筛选 -->
<div class="card mb-4 fade-in">
    <div class="card-body">
        <form method="get" asp-action="Users" class="row g-3">
            <div class="col-md-4">
                <input type="text" name="search" class="form-control" placeholder="搜索用户名、姓名、邮箱、学号..." value="@search">
            </div>
            <div class="col-md-3">
                <select name="filter" class="form-select">
                    <option value="all" @@(filter == "all" ? "selected" : "")>全部用户</option>
                    <option value="admin" @@(filter == "admin" ? "selected" : "")>管理员</option>
                    <option value="verified" @@(filter= ="verified" ? "selected" : "" )>已认证</option>
                    <option value="enabled" @@(filter= ="enabled" ? "selected" : "" )>已启用</option>
                    <option value="disabled" @@(filter= ="disabled" ? "selected" : "" )>已禁用</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search"></i> 搜索
                </button>
            </div>
            <div class="col-md-3">
                <a asp-action="Users" class="btn btn-outline-secondary w-100">重置</a>
            </div>
        </form>
    </div>
</div>

@if (!users.Any())
{
    <div class="card text-center py-5">
        <div class="card-body">
            <i class="bi bi-people fs-1 text-muted mb-3"></i>
            <h5 class="text-muted">暂无用户</h5>
            <p class="text-muted">没有找到符合条件的用户</p>
        </div>
    </div>
}
else
{
    <div class="card fade-in">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>用户名</th>
                            <th>真实姓名</th>
                            <th>学号</th>
                            <th>邮箱</th>
                            <th>状态</th>
                            <th>注册时间</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in users)
                        {
                            <tr>
                                <td>@user.Id</td>
                                <td>
                                    <strong>@user.Username</strong>
                                    @if (user.IsAdmin)
                                    {
                                        <span class="badge bg-danger ms-1">管理员</span>
                                    }
                                </td>
                                <td>@user.RealName</td>
                                <td>@user.StudentId</td>
                                <td>@user.Email</td>
                                <td>
                                    @if (user.IsVerified)
                                    {
                                        <span class="badge bg-success">已认证</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">未认证</span>
                                    }
                                    @if (user.IsEnabled)
                                    {
                                        <span class="badge bg-primary">已启用</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">已禁用</span>
                                    }
                                </td>
                                <td>@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="UserDetails" asp-route-id="@user.Id" class="btn btn-outline-info">
                                            <i class="bi bi-eye"></i> 详情
                                        </a>
                                        <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-outline-primary">
                                            <i class="bi bi-pencil"></i> 编辑
                                        </a>
                                        <button type="button" class="btn btn-outline-warning toggle-status" data-user-id="@user.Id" data-enabled="@user.IsEnabled.ToString().ToLower()">
                                            <i class="bi bi-@(user.IsEnabled ? "x-circle" : "check-circle")"></i> @(user.IsEnabled ? "禁用" : "启用")
                                        </button>
                                        @if (!user.IsAdmin)
                                        {
                                            <button type="button" class="btn btn-outline-danger toggle-admin" data-user-id="@user.Id">
                                                <i class="bi bi-shield-check"></i> 设为管理员
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-outline-secondary toggle-admin" data-user-id="@user.Id">
                                                <i class="bi bi-shield-x"></i> 取消管理员
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- 分页 -->
    @if (totalPages > 1)
    {
        <nav aria-label="分页" class="mt-4">
            <ul class="pagination justify-content-center">
                @if (currentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Users" asp-route-page="@(currentPage - 1)" asp-route-search="@search" asp-route-filter="@filter">上一页</a>
                    </li>
                }
                @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" asp-action="Users" asp-route-page="@i" asp-route-search="@search" asp-route-filter="@filter">@i</a>
                    </li>
                }
                @if (currentPage < totalPages)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Users" asp-route-page="@(currentPage + 1)" asp-route-search="@search" asp-route-filter="@filter">下一页</a>
                    </li>
                }
            </ul>
        </nav>
    }
}

@section Scripts {
    <script>
        // 切换用户启用状态
        document.querySelectorAll('.toggle-status').forEach(btn => {
            btn.addEventListener('click', function() {
                const userId = this.dataset.userId;
                const isEnabled = this.dataset.enabled === 'true';
                
                if (!confirm(`确定要${isEnabled ? '禁用' : '启用'}该用户吗？`)) {
                    return;
                }

                fetch('@Url.Action("ToggleUserStatus", "Admin")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: 'id=' + userId
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert(data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('操作失败，请稍后重试');
                });
            });
        });

        // 切换管理员权限
        document.querySelectorAll('.toggle-admin').forEach(btn => {
            btn.addEventListener('click', function() {
                const userId = this.dataset.userId;
                const isAdmin = this.textContent.includes('取消');
                
                if (!confirm(`确定要${isAdmin ? '取消' : '授予'}该用户的管理员权限吗？`)) {
                    return;
                }

                fetch('@Url.Action("ToggleAdminStatus", "Admin")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: 'id=' + userId
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert(data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('操作失败，请稍后重试');
                });
            });
        });
    </script>
}

