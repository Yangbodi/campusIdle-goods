@using CampusIdleGoods.Models
@{
    ViewData["Title"] = "消息";
    var chatList = ViewBag.ChatList as List<dynamic> ?? new List<dynamic>();
    var unreadCount = ViewBag.UnreadCount as int? ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold">
        <i class="bi bi-chat-dots"></i> 消息
        @if (unreadCount > 0)
        {
            <span class="badge bg-danger ms-2">@unreadCount</span>
        }
    </h3>
</div>

@if (!chatList.Any())
{
    <div class="card text-center py-5">
        <div class="card-body">
            <i class="bi bi-chat-dots fs-1 text-muted mb-3"></i>
            <h5 class="text-muted">暂无消息</h5>
            <p class="text-muted">您还没有任何聊天记录</p>
        </div>
    </div>
}
else
{
    <div class="card fade-in">
        <div class="card-body p-0">
            <div class="list-group list-group-flush">
                @foreach (var chat in chatList)
                {
                    var otherUser = chat.OtherUser as User;
                    var lastMessage = chat.LastMessage as Message;
                    var unreadCountItem = chat.UnreadCount as int? ?? 0;
                    var product = chat.Product as Product;
                    
                    <a asp-action="Chat" asp-route-userId="@otherUser.Id" asp-route-productId="@product?.Id" class="list-group-item list-group-item-action">
                        <div class="d-flex w-100 align-items-start">
                            <!-- 头像 -->
                            <div class="me-3">
                                @if (!string.IsNullOrEmpty(otherUser.AvatarPath))
                                {
                                    <img src="@otherUser.AvatarPath" class="rounded-circle" style="width: 50px; height: 50px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                        <span class="text-white fw-bold">@otherUser.RealName[0]</span>
                                    </div>
                                }
                            </div>
                            
                            <!-- 消息内容 -->
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <h6 class="mb-0">
                                        @otherUser.RealName
                                        @if (unreadCountItem > 0)
                                        {
                                            <span class="badge bg-danger ms-2">@unreadCountItem</span>
                                        }
                                    </h6>
                                    <small class="text-muted">@lastMessage.CreatedAt.ToString("MM-dd HH:mm")</small>
                                </div>
                                
                                <p class="mb-1 text-muted" style="display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;">
                                    @if (lastMessage.SenderId == CampusIdleGoods.Helpers.SessionHelper.GetUserId(Context.Session))
                                    {
                                        <span class="text-muted">我：</span>
                                    }
                                    @lastMessage.Content
                                </p>
                                
                                @if (product != null)
                                {
                                    <div class="d-flex align-items-center mt-1">
                                        <i class="bi bi-box text-primary me-1"></i>
                                        <small class="text-primary">关联商品：@product.Title</small>
                                    </div>
                                }
                            </div>
                        </div>
                    </a>
                }
            </div>
        </div>
    </div>
}

