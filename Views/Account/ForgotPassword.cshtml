@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "忘记密码";
}

<div class="auth-container">
    <div class="auth-card fade-in">
        <div class="text-center mb-4">
            <div class="mb-3">
                <i class="bi bi-key fs-1 text-primary"></i>
            </div>
            <h2 class="fw-bold text-gradient mb-2">忘记密码</h2>
            <p class="text-muted">请输入您的邮箱地址，我们将发送密码重置链接到您的邮箱。</p>
        </div>
        
        <form asp-action="ForgotPassword" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-4">
                <label asp-for="Email" class="form-label">
                    <i class="bi bi-envelope"></i> 邮箱地址
                </label>
                <input asp-for="Email" class="form-control" type="email" placeholder="请输入您的注册邮箱" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="d-grid mb-3">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-send"></i> 发送重置链接
                </button>
            </div>

            <div class="text-center">
                <a asp-action="Login" class="text-decoration-none">
                    <i class="bi bi-arrow-left"></i> 返回登录
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

