@model ChangePasswordViewModel
@{
    ViewData["Title"] = "修改密码";
}

<div class="row g-4">
    <div class="col-md-3">

        <div class="card mt-3 profile-menu">
            <div class="list-group list-group-flush">
                <a asp-action="Profile" class="list-group-item list-group-item-action">
                    <i class="bi bi-person"></i> 个人信息
                </a>
                <a asp-action="EditProfile" class="list-group-item list-group-item-action">
                    <i class="bi bi-pencil"></i> 编辑资料
                </a>
                <a asp-action="ChangePassword" class="list-group-item list-group-item-action active">
                    <i class="bi bi-key"></i> 修改密码
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-9">
        <div class="card fade-in">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-shield-lock"></i> 修改密码</h5>
            </div>
            <div class="card-body">
                <form asp-action="ChangePassword" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-4">
                        <label asp-for="CurrentPassword" class="form-label">
                            <i class="bi bi-lock"></i> 当前密码
                        </label>
                        <input asp-for="CurrentPassword" class="form-control" placeholder="请输入当前密码" />
                        <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="NewPassword" class="form-label">
                            <i class="bi bi-lock-fill"></i> 新密码
                        </label>
                        <input asp-for="NewPassword" class="form-control" placeholder="请输入新密码（至少6位）" />
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                        <small class="form-text text-muted">密码长度至少6个字符</small>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label">
                            <i class="bi bi-lock-fill"></i> 确认新密码
                        </label>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="请再次输入新密码" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> <strong>提示：</strong>修改密码后，您需要使用新密码重新登录。
                    </div>

                    <div class="d-flex gap-2 justify-content-end mt-4">
                        <a asp-action="Profile" class="btn btn-secondary">
                            <i class="bi bi-x-circle"></i> 取消
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i> 确认修改
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

