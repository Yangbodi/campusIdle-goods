@model ResetPasswordViewModel
@{
    ViewData["Title"] = "重置密码";
}

<div class="auth-container">
    <div class="auth-card fade-in">
        <div class="text-center mb-4">
            <div class="mb-3">
                <i class="bi bi-shield-lock fs-1 text-primary"></i>
            </div>
            <h2 class="fw-bold text-gradient mb-2">重置密码</h2>
            <p class="text-muted">请设置您的新密码</p>
        </div>
        
        <form asp-action="ResetPassword" method="post">
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="Token" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">
                    <i class="bi bi-lock"></i> 新密码
                </label>
                <input asp-for="Password" class="form-control" placeholder="请输入新密码（至少6位）" />
                <span asp-validation-for="Password" class="text-danger"></span>
                <small class="form-text text-muted">密码长度至少6个字符</small>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label">
                    <i class="bi bi-lock-fill"></i> 确认新密码
                </label>
                <input asp-for="ConfirmPassword" class="form-control" placeholder="请再次输入新密码" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="d-grid mb-3">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-check-circle"></i> 重置密码
                </button>
            </div>

            <div class="text-center">
                <a asp-action="Login" class="text-decoration-none">
                    <i class="bi bi-arrow-left"></i> 返回登录
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

