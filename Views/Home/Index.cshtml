@{
    ViewData["Title"] = "首页";
}

<div class="hero-section text-center fade-in">
    <div class="container">
        <h1 class="display-3 fw-bold mb-3">校园闲置好物阁</h1>
        <p class="lead mb-4">让闲置物品找到新主人，让校园生活更美好</p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            @if (CampusIdleGoods.Helpers.SessionHelper.IsLoggedIn(Context.Session))
            {
                <a asp-controller="Product" asp-action="Create" class="btn btn-light btn-lg">
                    <i class="bi bi-plus-circle"></i> 立即发布
                </a>
            }
            else
            {
                <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg">
                    <i class="bi bi-person-plus"></i> 免费注册
                </a>
            }
            <a asp-controller="Product" asp-action="Browse" class="btn btn-outline-light btn-lg">
                <i class="bi bi-search"></i> 浏览商品
            </a>
        </div>
    </div>
</div>

<!-- 功能特色 -->
<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card feature-card h-100 fade-in">
            <div class="card-body text-center">
                <div class="mb-3">
                    <i class="bi bi-box-seam text-primary" style="font-size: 3rem;"></i>
                </div>
                <h4 class="card-title fw-bold">轻松发布</h4>
                <p class="card-text text-muted">简单几步即可发布您的闲置物品，支持多图上传</p>
                @if (CampusIdleGoods.Helpers.SessionHelper.IsLoggedIn(Context.Session))
                {
                    <a asp-controller="Product" asp-action="Create" class="btn btn-primary mt-3">
                        <i class="bi bi-plus-circle"></i> 立即发布
                    </a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-primary mt-3">
                        <i class="bi bi-box-arrow-in-right"></i> 登录后发布
                    </a>
                }
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card feature-card h-100 fade-in">
            <div class="card-body text-center">
                <div class="mb-3">
                    <i class="bi bi-search text-primary" style="font-size: 3rem;"></i>
                </div>
                <h4 class="card-title fw-bold">智能搜索</h4>
                <p class="card-text text-muted">强大的搜索和筛选功能，快速找到心仪的商品</p>
                <a asp-controller="Product" asp-action="Browse" class="btn btn-primary mt-3">
                    <i class="bi bi-grid"></i> 浏览商品
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card feature-card h-100 fade-in">
            <div class="card-body text-center">
                <div class="mb-3">
                    <i class="bi bi-shield-check text-primary" style="font-size: 3rem;"></i>
                </div>
                <h4 class="card-title fw-bold">安全可靠</h4>
                <p class="card-text text-muted">实名认证保障，学号验证，交易安全放心</p>
                @if (CampusIdleGoods.Helpers.SessionHelper.IsLoggedIn(Context.Session))
                {
                    <a asp-controller="Favorite" asp-action="Index" class="btn btn-primary mt-3">
                        <i class="bi bi-heart"></i> 我的收藏
                    </a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Register" class="btn btn-primary mt-3">
                        <i class="bi bi-person-plus"></i> 立即注册
                    </a>
                }
            </div>
        </div>
    </div>
</div>

<!-- 热门分类 -->
@if (ViewBag.PopularCategories != null && ((List<CampusIdleGoods.Models.Category>)ViewBag.PopularCategories).Any())
{
    <div class="row mb-5">
        <div class="col-12">
            <h3 class="fw-bold mb-4">
                <i class="bi bi-grid-3x3-gap text-primary"></i> 热门分类
            </h3>
            <div class="row g-3">
                @foreach (var category in ViewBag.PopularCategories as List<CampusIdleGoods.Models.Category>)
                {
                    var iconClass = "bi-grid";
                    if (category.Name.Contains("图书") || category.Name.Contains("书籍")) { iconClass = "bi-book"; }
                    else if (category.Name.Contains("电子") || category.Name.Contains("数码")) { iconClass = "bi-laptop"; }
                    else if (category.Name.Contains("服饰") || category.Name.Contains("衣服")) { iconClass = "bi-bag"; }
                    else if (category.Name.Contains("运动") || category.Name.Contains("体育")) { iconClass = "bi-bicycle"; }
                    else if (category.Name.Contains("生活") || category.Name.Contains("日用")) { iconClass = "bi-house"; }
                    else if (category.Name.Contains("美妆") || category.Name.Contains("化妆")) { iconClass = "bi-palette"; }
                    else if (category.Name.Contains("文具") || category.Name.Contains("办公")) { iconClass = "bi-pencil"; }
                    else if (category.Name.Contains("其他")) { iconClass = "bi-box-seam"; }
                    
                    <div class="col-6 col-md-3 col-lg-2">
                        <a asp-controller="Product" asp-action="Category" asp-route-id="@category.Id" class="text-decoration-none">
                            <div class="card text-center h-100 hover-card">
                                <div class="card-body py-3">
                                    <i class="bi @iconClass text-primary mb-2" style="font-size: 2rem;"></i>
                                    <h6 class="card-title text-dark mb-0 small">@category.Name</h6>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
}

<!-- 最新商品 -->
@if (ViewBag.LatestProducts != null && ((List<CampusIdleGoods.Models.Product>)ViewBag.LatestProducts).Any())
{
    <div class="row mb-5">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold mb-0">最新商品</h3>
                <a asp-controller="Product" asp-action="Browse" class="btn btn-outline-primary">
                    查看更多 <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            <div class="row g-4">
                @foreach (var product in ViewBag.LatestProducts as List<CampusIdleGoods.Models.Product>)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id" class="text-decoration-none">
                            <div class="card h-100 product-card fade-in">
                                @if (product.Images != null && product.Images.Any())
                                {
                                    <img src="@product.Images.First().ImagePath" class="card-img-top" alt="@product.Title" style="height: 200px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                        <i class="bi bi-image fs-1 text-muted"></i>
                                    </div>
                                }
                                <div class="card-body d-flex flex-column">
                                    <h6 class="card-title text-dark mb-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 48px;">@product.Title</h6>
                                    <div class="mb-2">
                                        <span class="h6 text-primary fw-bold">¥@product.Price.ToString("F2")</span>
                                        @if (product.OriginalPrice.HasValue)
                                        {
                                            <span class="text-muted text-decoration-line-through small ms-1">¥@product.OriginalPrice.Value.ToString("F2")</span>
                                        }
                                    </div>
                                    <div class="mt-auto">
                                        <small class="text-muted">
                                            <i class="bi bi-eye"></i> @product.ViewCount |
                                            <i class="bi bi-clock"></i> @product.CreatedAt.ToString("MM-dd")
                                        </small>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
}

